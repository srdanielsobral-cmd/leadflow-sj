# No Railway, tambem funciona usando as variaveis automaticas:
# MYSQLHOST
# MYSQLPORT
# MYSQLUSER
# MYSQLPASSWORD
# MYSQLDATABASE
# DATABASE_URL ou MYSQL_URL

# Para banco MySQL online que exige SSL, como Aiven:
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Recuperacao de acesso admin:
# Use RESET_ADMIN=1 temporariamente para resetar o admin.
# Depois de entrar no sistema, remova RESET_ADMIN ou deixe RESET_ADMIN=0.
RESET_ADMIN=0
ADMIN_USUARIO=admin
